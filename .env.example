# --- Servidor ---
PORT=3000

# --- Postgres ---
# Ejemplo local: postgresql://faro:faro@localhost:5432/faro
# Ejemplo Render/Railway/Supabase: te dan la connection string ya armada
DATABASE_URL=postgresql://faro:faro@localhost:5432/faro
PGSSL=false

# --- JWT propio (sesion del widget) ---
# Genera uno fuerte con: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=cambia_esto_por_un_secreto_largo_y_random
JWT_EXPIRES_IN=12h

# --- Ventana de tolerancia para el timestamp firmado por el plugin (anti-replay) ---
AUTH_TIMESTAMP_TOLERANCE_SECONDS=300

# --- CORS ---
# Lista separada por comas de origenes permitidos (dominios Moodle + hosting del widget)
CORS_ALLOWED_ORIGINS=*
